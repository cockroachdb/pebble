3:
  000005:[k#90,SET-o#150,SET]
4:
  000006:[m#30,SET-u#60,SET]

set-hints
L0 a-k 110 300-300
L1 b-r 90 200-230
L0 b-r 90 200-230
----
L0 a-k 110 300-300
L1 b-r 90 200-230
L0 b-r 90 200-230


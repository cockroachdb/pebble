  (none)
Compactions:
  [JOB 100] compacted L2 [000004] (784 B) + L3 [000005] (784 B) -> L6 [] (0 B), in 1.0s, output rate 0 B/s

# Verify that a hint does not delete a file (000004) that contains keys more
# recent than the oldest tombstone contained by the hint. This is possible if
# an open snapshots prevents a hint from being resolved and in the meantime
# ordinary compactions modify the LSM.

define snapshots=(70)
L2
d.SET.110:d i.SET.210:i
L3
k.SET.90:k o.SET.150:o
L4
m.SET.30:m u.SET.60:u
----
2:
  000004:[d#110,SET-i#210,SET]
3:
  000005:[k#90,SET-o#150,SET]
4:
  000006:[m#30,SET-u#60,SET]

set-hints
L1 b-r 90 200-230
----
L1 b-r 90 200-230


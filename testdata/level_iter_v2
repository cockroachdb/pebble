# Tests for levelIterV2 with a focus on the TrySeekUsingNext (TSUN) code paths
# in level_iter_v2.go.

# ---------------------------------------------------------------------------
# Same-file fast path: TSUN seek to a key still inside the active file's
# bounds avoids re-finding the file.
# ---------------------------------------------------------------------------

define
F
  a#10,SET d#8,SET g#6,SET
F
  k#5,SET n#4,SET q#3,SET
----
F0: a#10,SET-g#6,SET
F1: k#5,SET-q#3,SET

iter
seek-ge a
seek-ge c try-seek-using-next
seek-ge d try-seek-using-next
seek-ge f try-seek-using-next
----
seek-ge a:                     a#10,SET [?, k):{}
seek-ge c try-seek-using-next: d#8,SET [?, k):{}
seek-ge d try-seek-using-next: d#8,SET [?, k):{}
seek-ge f try-seek-using-next: g#6,SET [?, k):{}

# ---------------------------------------------------------------------------
# Sequential file scan: TSUN seeks that cross one or two file boundaries
# should be served by the forward-scan path in findFileGE (up to ~4 files).
# ---------------------------------------------------------------------------

define
F
  a#10,SET b#9,SET
F
  d#8,SET e#7,SET
F
  g#6,SET h#5,SET
F
  j#4,SET k#3,SET
----
F0: a#10,SET-b#9,SET
F1: d#8,SET-e#7,SET
F2: g#6,SET-h#5,SET
F3: j#4,SET-k#3,SET

iter
seek-ge a
seek-ge d try-seek-using-next
seek-ge g try-seek-using-next
seek-ge j try-seek-using-next
----
seek-ge a:                     a#10,SET [?, d):{}
seek-ge d try-seek-using-next: d#8,SET [?, g):{}
seek-ge g try-seek-using-next: g#6,SET [?, j):{}
seek-ge j try-seek-using-next: j#4,SET [?, ∞):{}

# Same files, but TSUN seeks that land in the gap between files. The level
# iterator emits a synthetic boundary at the next file's smallest key.
iter
seek-ge a
seek-ge c try-seek-using-next
seek-ge f try-seek-using-next
seek-ge i try-seek-using-next
----
seek-ge a:                     a#10,SET [?, d):{}
seek-ge c try-seek-using-next: d#inf,BDRY [?, d):{}
seek-ge f try-seek-using-next: g#inf,BDRY [?, g):{}
seek-ge i try-seek-using-next: j#inf,BDRY [?, j):{}


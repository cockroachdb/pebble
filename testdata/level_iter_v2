# ---------------------------------------------------------------------------
# Synthetic boundary handling: when the prior result was a synthetic file
# boundary, a TSUN seek can land (a) before the boundary, (b) at the
# boundary, or (c) past the boundary.
# ---------------------------------------------------------------------------

define
F
  a#10,SET b#9,SET
F
  f#8,SET g#7,SET
----
F0: a#10,SET-b#9,SET
F1: f#8,SET-g#7,SET

# Position at the synthetic boundary, then TSUN at the boundary key.
iter
seek-ge c
seek-ge f try-seek-using-next
----
seek-ge c:                     f#inf,BDRY [?, f):{}
seek-ge f try-seek-using-next: f#8,SET [?, ∞):{}

# Position at the synthetic boundary, then TSUN past the boundary.
iter
seek-ge c
seek-ge g try-seek-using-next
----
seek-ge c:                     f#inf,BDRY [?, f):{}
seek-ge g try-seek-using-next: g#7,SET [?, ∞):{}

# Position at the synthetic boundary, then TSUN at a key still before the
# boundary (must still return the boundary).
iter
seek-ge c
seek-ge d try-seek-using-next
----
seek-ge c:                     f#inf,BDRY [?, f):{}
seek-ge d try-seek-using-next: f#inf,BDRY [?, f):{}


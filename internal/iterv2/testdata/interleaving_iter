# Direction change from backward-exhausted with lower bound.
# After SetBounds(m, .), SeekLT(a) returns nil (backward-exhausted).
# Next() must respect the lower bound and return p (first key >= m),
# not a (the absolute first key).

define-points
a#10,SET
p#5,SET
z#1,SET
----
a#10,SET, p#5,SET, z#1,SET

define-spans
----

# With nil upper from set-bounds, the last gap is unbounded above.
iter lower=a upper=zz
set-bounds m .
seek-lt a
next
----
set-bounds m .: ok
seek-lt a:      .
next:           p#5,SET [?, ∞)

# Direction change from forward-exhausted with upper bound.
# After SetBounds(., m), SeekGE(z) returns nil (forward-exhausted).
# Prev() must respect the upper bound and return a (last key < m),
# not p (the key at index len-2 which is >= upper).

iter lower=a upper=zz
set-bounds . m
seek-ge z
prev
----
set-bounds . m: ok
seek-ge z:      .
prev:           a#10,SET [-∞, ?)

# Backward gap span end clamped to upper bound.
# With upper=h, the span [c,j) is above upper. When going backward from
# a forward-exhausted state, the gap's upper boundary should be h (the
# upper bound), not j (the span start above the gap).

define-points
d#4,SET
----
d#4,SET

define-spans
c-j:{(#5,RANGEDEL)}
----
c-j:{(#5,RANGEDEL)}

iter lower=a upper=z
set-bounds . h
seek-ge z
prev
----
set-bounds . h: ok
seek-ge z:      .
prev:           d#4,SET [c, ?) {(#5,RANGEDEL)}

# Stale fragment state after SeekGE/SeekLT returns nil.
# When SeekGE or SeekLT exhausts points, the fragment iterator state
# must be reset so that subsequent Next/Prev calls don't emit spurious
# boundary keys from the stale fragment position.

define-points
b#8,SET
d#4,SET
----
b#8,SET, d#4,SET

define-spans
c-g:{(#5,RANGEDEL)}
----
c-g:{(#5,RANGEDEL)}

# SeekGE positions fragments, then SeekGE exhausts points.
# Next must return nil, not a stale boundary.
iter lower=a upper=z
seek-ge a
seek-ge z
next
----
seek-ge a: b#8,SET [?, c)
seek-ge z: .
next:      .

# SeekLT positions fragments, then SeekLT exhausts points.
# Prev must return nil, not a stale boundary.
iter lower=a upper=z
seek-lt z
seek-lt a
prev
----
seek-lt z: g#inf,BDRY [g, ?)
seek-lt a: .
prev:      .

# No spurious boundary at upper bound for clipped span.
# When a span extends past upper, the iterator should exhaust at upper
# without emitting a boundary key there.

define-points
d#4,SET
----
d#4,SET

define-spans
c-j:{(#5,RANGEDEL)}
----
c-j:{(#5,RANGEDEL)}

# With nil lower from set-bounds, the first gap's backward boundary is
# unbounded.
iter lower=a upper=z
set-bounds . h
first
next
----
set-bounds . h: ok
first:          c#inf,BDRY [?, c)
next:           d#4,SET [?, h) {(#5,RANGEDEL)}

# Same test but backward: no spurious boundary at lower bound.
